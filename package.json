{
  "author": "Serhii Pimenov <serhii@pimenov.com.ua>",
  "name": "@olton/reactive",
  "version": "1.0.0",
  "description": "Reactive model with two-way data binding directly in your HTML.",
  "keywords": [
    "javascript",
    "html",
    "javascript",
    "binding"
  ],
  "funding": {
    "type": "patreon",
    "url": "https://www.patreon.com/metroui"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/olton/reactive.git"
  },
  "license": "MIT",
  "main": "dist/model.js",
  "type": "module",
  "types": "types/model.d.ts",
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "clean": "shx rm -rf lib/*",
    "build": "npm run clean && cross-env NODE_NO_WARNINGS=1 MODE=production node build.js",
    "dev": "npm run clean && cross-env NODE_NO_WARNINGS=1 MODE=development node build.js",
    "pub": "npm run build && npm publish --access public",
    "test": "latte --dom --progress=none -v",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "start": "vite"
  },
  "pre-commit": [],
  "browserslist": [
    "last 2 versions"
  ],
  "devDependencies": {
    "@olton/esbuild-plugin-progress": "^0.4.0",
    "@olton/latte": "^0.17.5",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "esbuild-plugin-replace": "^1.4.0",
    "oxlint": "^1.73.0",
    "shx": "^0.4.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
